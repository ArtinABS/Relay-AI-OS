AI_PROVIDER=openrouter
AI_MODEL=openrouter/free
AI_API_KEY=

# Recommended no-cost development path: create an OpenRouter key and use
# the free router. You can paste the key into either OPENROUTER_API_KEY
# or AI_API_KEY.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional Gemini path if it is available in your region/account.
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Optional paid/provider-specific overrides.
OPENAI_API_KEY=
OPENAI_MODEL=openai/gpt-4.1-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=anthropic/claude-3.5-haiku
NEXT_PUBLIC_ENABLE_COPILOTKIT=false

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3000/api/auth/callback/github
# Defaults to read:user user:email repo read:org. Remove repo if you only want public/basic access.
GITHUB_OAUTH_SCOPES=

DATABASE_URL=postgres://postgres:postgres@localhost:5432/daily_work_agent

# Optional local-development token for testing Google tools before wiring
# encrypted per-user token storage.
GOOGLE_DEV_ACCESS_TOKEN=
GOOGLE_DEV_REFRESH_TOKEN=

INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
