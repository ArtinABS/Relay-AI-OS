{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Relay: Start dev server",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "next",
        "pattern": [
          {
            "regexp": "^$",
            "file": 1,
            "location": 2,
            "message": 3
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*Next\\.js.*",
          "endsPattern": ".*Ready in.*"
        }
      },
      "presentation": {
        "panel": "dedicated",
        "reveal": "always",
        "clear": true
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Relay: Stop dev server",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\stop-relay-dev.ps1"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "panel": "dedicated",
        "reveal": "always",
        "clear": true
      }
    },
    {
      "label": "Relay: Restart dev server",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Relay: Stop dev server",
        "Relay: Start dev server"
      ],
      "problemMatcher": []
    }
  ]
}
